<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Step-Up SIP Calculator</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="calculator-container">
        <h1>Financial Calculators</h1>

        <div class="tabs">
            <a href="/sip" class="tab-btn">SIP</a>
            <a href="/swp" class="tab-btn">SWP</a>
            <a href="/stepupsip" class="tab-btn active">Step-Up SIP</a>
            <a href="/inflation" class="tab-btn">SIP with Inflation</a>
            <a href="/incometax" class="tab-btn">Income Tax</a>
            <a href="/fd" class="tab-btn">FD</a>
        </div>

        <div class="calc-grid">
            <div class="inputs-side">
                <div class="input-group">
                    <label>Monthly investment (₹)</label>
                    <input type="number" id="stepupAmount" value="10000" oninput="syncFields('stepupAmount', 'stepupAmountSlider')">
                    <input type="range" id="stepupAmountSlider" min="500" max="100000" step="500" value="10000" oninput="syncFields('stepupAmountSlider', 'stepupAmount')">
                </div>
                <div class="input-group">
                    <label>Expected return rate (p.a. %)</label>
                    <input type="number" id="stepupRate" value="12" step="0.1" oninput="syncFields('stepupRate', 'stepupRateSlider')">
                    <input type="range" id="stepupRateSlider" min="1" max="30" step="0.1" value="12" oninput="syncFields('stepupRateSlider', 'stepupRate')">
                </div>
                <div class="input-group">
                    <label>Step-up every year (%)</label>
                    <input type="number" id="stepupStep" value="10" step="0.1" oninput="syncFields('stepupStep', 'stepupStepSlider')">
                    <input type="range" id="stepupStepSlider" min="0" max="30" step="0.1" value="10" oninput="syncFields('stepupStepSlider', 'stepupStep')">
                </div>
                <div class="input-group">
                    <label>Time period (Years)</label>
                    <input type="number" id="stepupYears" value="10" oninput="syncFields('stepupYears', 'stepupYearsSlider')">
                    <input type="range" id="stepupYearsSlider" min="1" max="40" step="1" value="10" oninput="syncFields('stepupYearsSlider', 'stepupYears')">
                </div>
            </div>
            <div class="outputs-side">
                <div id="stepupResultOutputs" class="results-text"></div>
                <div class="chart-wrapper">
                    <canvas id="stepupChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <script src="/script.js"></script>
    <script>
        window.addEventListener('DOMContentLoaded', () => {
            if (typeof computeStepUpSIP === 'function') {
                computeStepUpSIP();
            }
        });
    </script>
</body>
</html>
