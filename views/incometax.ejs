<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Income Tax Calculator</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="calculator-container">
        <h1>Financial Calculators</h1>

        <div class="tabs">
            <a href="/sip" class="tab-btn">SIP</a>
            <a href="/swp" class="tab-btn">SWP</a>
            <a href="/stepupsip" class="tab-btn">Step-Up SIP</a>
            <a href="/inflation" class="tab-btn">SIP with Inflation</a>
            <a href="/incometax" class="tab-btn active">Income Tax</a>
            <a href="/fd" class="tab-btn">FD</a>
        </div>

        <div class="calc-grid">
            <div class="inputs-side">
                <div class="input-group">
                    <label>Annual taxable income (₹)</label>
                    <input type="number" id="incomeTaxIncome" value="1200000" oninput="syncFields('incomeTaxIncome', 'incomeTaxIncomeSlider')">
                    <input type="range" id="incomeTaxIncomeSlider" min="100000" max="5000000" step="100000" value="1200000" oninput="syncFields('incomeTaxIncomeSlider', 'incomeTaxIncome')">
                </div>
                <div class="input-group">
                    <label>Age group</label>
                    <select id="incomeTaxAge" onchange="computeIncomeTax()">
                        <option value="below60">Below 60</option>
                        <option value="60to80">60 - 80</option>
                        <option value="above80">Above 80</option>
                    </select>
                </div>
                <div class="input-group">
                    <label>Tax regime</label>
                    <select id="incomeTaxRegime" onchange="computeIncomeTax()">
                        <option value="old">Old Regime</option>
                        <option value="new">New Regime</option>
                    </select>
                </div>
                <div class="input-group">
                    <label>Section 80C / 80CCC / 80CCD deduction (₹)</label>
                    <input type="number" id="incomeTaxDeduction" value="150000" oninput="syncFields('incomeTaxDeduction', 'incomeTaxDeductionSlider')">
                    <input type="range" id="incomeTaxDeductionSlider" min="0" max="500000" step="5000" value="150000" oninput="syncFields('incomeTaxDeductionSlider', 'incomeTaxDeduction')">
                </div>
                <div class="input-group">
                    <label>Standard deduction (₹)</label>
                    <input type="number" id="incomeTaxStandardDeduction" value="50000" oninput="syncFields('incomeTaxStandardDeduction', 'incomeTaxStandardDeductionSlider')">
                    <input type="range" id="incomeTaxStandardDeductionSlider" min="0" max="100000" step="5000" value="50000" oninput="syncFields('incomeTaxStandardDeductionSlider', 'incomeTaxStandardDeduction')">
                </div>
            </div>
            <div class="outputs-side">
                <div id="incomeTaxResultOutputs" class="results-text"></div>
                <div class="chart-wrapper">
                    <canvas id="incomeTaxChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <script src="/script.js"></script>
    <script>
        window.addEventListener('DOMContentLoaded', () => {
            if (typeof computeIncomeTax === 'function') {
                computeIncomeTax();
            }
        });
    </script>
</body>
</html>
