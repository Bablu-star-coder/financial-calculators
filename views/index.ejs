<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SWP Calculator</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="calculator-container">
        <h1>Financial Calculators</h1>
        
        <div class="tabs">
            <a href="/sip" class="tab-btn">SIP</a>
            <a href="/riskprofile" class="tab-btn">Risk Profile</a>
            <a href="/swp" class="tab-btn active">SWP</a>
            <a href="/stepupsip" class="tab-btn">Step-Up SIP</a>
            <a href="/inflation" class="tab-btn">SIP with Inflation</a>
            <a href="/incometax" class="tab-btn">Income Tax</a>
            <a href="/fd" class="tab-btn">FD</a>
        </div>

        <div class="calc-grid">
            <div class="inputs-side">
                <div class="input-group">
                    <label>Total investment (₹)</label>
                    <input type="number" id="swpLump" value="500000" oninput="syncFields('swpLump', 'swpLumpSlider')">
                    <input type="range" id="swpLumpSlider" min="10000" max="10000000" step="10000" value="500000" oninput="syncFields('swpLumpSlider', 'swpLump')">
                </div>
                <div class="input-group">
                    <label>Monthly withdrawal (₹)</label>
                    <input type="number" id="swpWithdraw" value="10000" oninput="syncFields('swpWithdraw', 'swpWithdrawSlider')">
                    <input type="range" id="swpWithdrawSlider" min="500" max="200000" step="500" value="10000" oninput="syncFields('swpWithdrawSlider', 'swpWithdraw')">
                </div>
                <div class="input-group">
                    <label>Expected return rate (p.a. %)</label>
                    <input type="number" id="swpRate" value="12" step="0.1" oninput="syncFields('swpRate', 'swpRateSlider')">
                    <input type="range" id="swpRateSlider" min="1" max="30" step="0.1" value="12" oninput="syncFields('swpRateSlider', 'swpRate')">
                </div>
                <div class="input-group">
                    <label>Time period (Years)</label>
                    <input type="number" id="swpYears" value="10" oninput="syncFields('swpYears', 'swpYearsSlider')">
                    <input type="range" id="swpYearsSlider" min="1" max="40" step="1" value="10" oninput="syncFields('swpYearsSlider', 'swpYears')">
                </div>
            </div>
            <div class="outputs-side">
                <div id="swpResultOutputs" class="results-text"></div>
                <div class="chart-wrapper">
                    <canvas id="swpChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="risk-questionnaire">
        <h2>Risk Profile Survey</h2>
        <p class="survey-intro">Answer these 9 questions to determine your SIP risk profile and apply it automatically on the SIP page.</p>
        <form id="riskSurveyForm">
            <div class="question-group">
                <label>1. What is your investment horizon?</label>
                <div class="radio-options">
                    <label><input type="radio" name="q1" value="1" checked> Less than 3 years</label>
                    <label><input type="radio" name="q1" value="2"> 3 - 7 years</label>
                    <label><input type="radio" name="q1" value="3"> More than 7 years</label>
                </div>
            </div>
            <div class="question-group">
                <label>2. How do you feel about market volatility?</label>
                <div class="radio-options">
                    <label><input type="radio" name="q2" value="1" checked> I prefer stable returns</label>
                    <label><input type="radio" name="q2" value="2"> Some ups and downs are okay</label>
                    <label><input type="radio" name="q2" value="3"> I can tolerate large swings</label>
                </div>
            </div>
            <div class="question-group">
                <label>3. What is your goal for this investment?</label>
                <div class="radio-options">
                    <label><input type="radio" name="q3" value="1" checked> Capital protection</label>
                    <label><input type="radio" name="q3" value="2"> Balanced growth</label>
                    <label><input type="radio" name="q3" value="3"> Aggressive wealth creation</label>
                </div>
            </div>
            <div class="question-group">
                <label>4. How long can you leave this money invested?</label>
                <div class="radio-options">
                    <label><input type="radio" name="q4" value="1" checked> Less than 3 years</label>
                    <label><input type="radio" name="q4" value="2"> 3 - 5 years</label>
                    <label><input type="radio" name="q4" value="3"> More than 5 years</label>
                </div>
            </div>
            <div class="question-group">
                <label>5. How would you react to a 10% loss?</label>
                <div class="radio-options">
                    <label><input type="radio" name="q5" value="1" checked> I would sell quickly</label>
                    <label><input type="radio" name="q5" value="2"> I would wait and decide</label>
                    <label><input type="radio" name="q5" value="3"> I would hold and stay calm</label>
                </div>
            </div>
            <div class="question-group">
                <label>6. How experienced are you with investments?</label>
                <div class="radio-options">
                    <label><input type="radio" name="q6" value="1" checked> Beginner</label>
                    <label><input type="radio" name="q6" value="2"> Some experience</label>
                    <label><input type="radio" name="q6" value="3"> Very experienced</label>
                </div>
            </div>
            <div class="question-group">
                <label>7. What is your primary source of future income?</label>
                <div class="radio-options">
                    <label><input type="radio" name="q7" value="1" checked> Salary or fixed income</label>
                    <label><input type="radio" name="q7" value="2"> Mixed sources</label>
                    <label><input type="radio" name="q7" value="3"> Investment returns</label>
                </div>
            </div>
            <div class="question-group">
                <label>8. If the market drops, what is your plan?</label>
                <div class="radio-options">
                    <label><input type="radio" name="q8" value="1" checked> Move to cash</label>
                    <label><input type="radio" name="q8" value="2"> Wait and review</label>
                    <label><input type="radio" name="q8" value="3"> Buy more selectively</label>
                </div>
            </div>
            <div class="question-group">
                <label>9. What is more important to you?</label>
                <div class="radio-options">
                    <label><input type="radio" name="q9" value="1" checked> Safety</label>
                    <label><input type="radio" name="q9" value="2"> Balance</label>
                    <label><input type="radio" name="q9" value="3"> Growth</label>
                </div>
            </div>
            <button type="button" class="primary-button" onclick="analyzeRiskProfile()">Analyze my risk profile</button>
            <div id="riskProfileResult" class="results-text"></div>
        </form>
    </div>

    <script src="/script.js"></script>
    <script>
        window.addEventListener('DOMContentLoaded', () => {
            if (typeof computeSWP === 'function') {
                computeSWP();
            }
        });
    </script>
</body>
</html>
